{
  "title": "FacePulse",
  "uid": "facepulse-main",
  "schemaVersion": 39,
  "refresh": "15s",
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "tags": ["facepulse"],
  "panels": [

    {
      "id": 1, "type": "stat",
      "title": "Unique Faces",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "facepulse-pg" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "facepulse-pg" },
        "rawSql": "SELECT COUNT(*) AS value FROM faces",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 2, "type": "stat",
      "title": "Identified",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "postgres", "uid": "facepulse-pg" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "facepulse-pg" },
        "rawSql": "SELECT COUNT(*) AS value FROM faces WHERE label <> ''",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 3, "type": "stat",
      "title": "Appearances (24 h)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "facepulse-pg" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] } },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "facepulse-pg" },
        "rawSql": "SELECT seen_at AS time, 1 AS value FROM appearances WHERE $__timeFilter(seen_at)",
        "format": "time_series", "refId": "A"
      }]
    },

    {
      "id": 4, "type": "stat",
      "title": "Most Seen",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "facepulse-pg" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "colorMode": "none", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "facepulse-pg" },
        "rawSql": "SELECT COALESCE(NULLIF(f.label,''), '#'||f.id::text) AS value FROM faces f JOIN appearances a ON a.face_id = f.id GROUP BY f.id, f.label ORDER BY COUNT(*) DESC LIMIT 1",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 5, "type": "timeseries",
      "title": "Appearances per hour",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "facepulse-pg" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "facepulse-pg" },
        "rawSql": "SELECT DATE_TRUNC('hour', a.seen_at) AS time, COALESCE(NULLIF(f.label,''), '#'||a.face_id::text) AS metric, COUNT(*) AS value FROM appearances a JOIN faces f ON f.id = a.face_id WHERE $__timeFilter(a.seen_at) GROUP BY DATE_TRUNC('hour', a.seen_at), metric ORDER BY time",
        "format": "time_series", "refId": "A"
      }]
    },

    {
      "id": 6, "type": "barchart",
      "title": "Top 10 by appearances",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "postgres", "uid": "facepulse-pg" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "orientation": "horizontal",
        "barWidth": 0.7,
        "legend": { "displayMode": "hidden", "showLegend": false },
        "tooltip": { "mode": "single" }
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "facepulse-pg" },
        "rawSql": "SELECT COALESCE(NULLIF(f.label,''), '#'||f.id::text) AS label, COUNT(a.id) AS appearances FROM faces f LEFT JOIN appearances a ON a.face_id = f.id WHERE $__timeFilter(a.seen_at) OR a.id IS NULL GROUP BY label ORDER BY appearances DESC LIMIT 10",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 7, "type": "timeseries",
      "title": "Faces enrolled over time (cumulative)",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "postgres", "uid": "facepulse-pg" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 15 }, "color": { "fixedColor": "#457b9d", "mode": "fixed" } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "hidden", "showLegend": false },
        "tooltip": { "mode": "single" }
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "facepulse-pg" },
        "rawSql": "SELECT created_at AS time, SUM(1) OVER (ORDER BY created_at) AS \"Enrolled faces\" FROM faces ORDER BY created_at",
        "format": "time_series", "refId": "A"
      }]
    }

  ]
}
